{
	"name": "gpad",
	"version": "1.0.0",
	"description": "GPad Electron desktop manager for Moonlight and Traversal",
	"main": "out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"build:icon": "node scripts/generate-icon.mjs",
		"dist": "npm run build:icon && npm run build && electron-builder"
	},
	"dependencies": {
		"lucide-react": "^0.469.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router-dom": "^6.30.1"
	},
	"devDependencies": {
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@types/three": "^0.181.0",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"electron": "latest",
		"electron-builder": "latest",
		"electron-vite": "latest",
		"png-to-ico": "^3.0.1",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	},
	"build": {
		"appId": "com.gpad.desktop",
		"productName": "GPad",
		"directories": {
			"output": "release"
		},
		"files": [
			"out/**/*",
			"package.json"
		],
		"extraResources": [
			{
				"from": "exe",
				"to": "exe",
				"filter": [
					"**/*"
				]
			}
		],
		"win": {
			"icon": "build/gpad-logo.ico",
			"target": [
				"nsis"
			]
		},
		"nsis": {
			"installerIcon": "build/gpad-logo.ico",
			"uninstallerIcon": "build/gpad-logo.ico"
		}
	}
}
